{
  "org_id": "default",
  "services": [
    {
      "id": "backend",
      "name": "Backend API",
      "aliases": ["backend", "api", "backend-api"],
      "owners": ["team-platform"],
      "repos": ["github.com/acme/backend"],
      "build_commands": ["npm install", "npm run build"],
      "test_commands": ["npm test"],
      "suggested_reviewers": ["team-platform"],
      "playbooks": [
        {
          "id": "backend-timeout",
          "title": "Backend timeout triage",
          "summary": "Check recent deploys, database saturation, and worker restart health.",
          "steps": [
            "Check deploy workflow status before runtime changes.",
            "Inspect postgres-main connection saturation.",
            "Restart backend-api workers only after approval."
          ],
          "tags": ["timeout", "database", "restart"]
        }
      ],
      "repositories": [
        {
          "provider": "github",
          "host": "github.com",
          "owner": "acme",
          "name": "backend",
          "default_branch": "main",
          "url": "https://github.com/acme/backend"
        }
      ],
      "environments": {
        "prod": {
          "runtime": {
            "provider": "kubernetes",
            "namespace": "prod",
            "workload": "backend-api"
          },
          "observability": {
            "metrics": "backend-prod",
            "errors": "backend-api"
          },
          "ci": {
            "provider": "github_actions",
            "workflow": "deploy-backend.yml"
          }
        },
        "staging": {
          "runtime": {
            "provider": "kubernetes",
            "namespace": "staging",
            "workload": "backend-api"
          },
          "observability": {
            "metrics": "backend-staging",
            "errors": "backend-api-staging"
          },
          "ci": {
            "provider": "github_actions",
            "workflow": "deploy-backend-staging.yml"
          }
        }
      },
      "runbooks": ["docs/backend-oncall.md"],
      "dependencies": ["postgres-main", "redis-cache"]
    }
  ]
}
